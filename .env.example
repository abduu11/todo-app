# Configuration de l'application TodoApp
# Copiez ce fichier en .env et remplissez les valeurs

# Base de données (SQLite en développement, PostgreSQL en production)
DATABASE_URL=sqlite:///todos.db

# Clé secrète Flask (générer une chaîne aléatoire)
SECRET_KEY=dev-secret-key-change-in-production

# Environnement Flask (development/production)
FLASK_ENV=development

# Port pour le serveur Flask
PORT=5000

# URL de l'application (pour les notifications)
APP_URL=http://localhost:5000

# ============================================================================
# Configuration des notifications email (Gmail SMTP)
# ============================================================================

# Activation du mode test (ne pas envoyer d'emails)
DRY_RUN=true

# Configuration SMTP Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-d-application

# Expéditeur et destinataire (optionnels)
EMAIL_FROM=votre@gmail.com
EMAIL_TO=destinataire@email.com

# ============================================================================
# Frontend React
# ============================================================================

# URL de l'API backend (utilisée par React)
REACT_APP_API_URL=http://localhost:5000

# ============================================================================
# Notes importantes
# ============================================================================

# Pour Gmail, créez un "mot de passe d'application" :
# 1. Allez sur https://myaccount.google.com/apppasswords
# 2. Sélectionnez "Mail" et "Autre (Nom personnalisé)"
# 3. Entrez "TodoApp" et générez le mot de passe
# 4. Utilisez ce mot de passe (16 caractères) pour SMTP_PASSWORD

# En production sur Render :
# - DATABASE_URL est automatiquement fournie par Render
# - SECRET_KEY est générée automatiquement
# - Les variables SMTP doivent être définies manuellement dans le dashboard
# - Définissez DRY_RUN=false pour activer les envois d'email