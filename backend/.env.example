# Copier ce fichier en .env et modifier les valeurs
# Configuration pour le développement
FLASK_APP=app.py
FLASK_ENV=development
DATABASE_URL=sqlite:///todos.db
SECRET_KEY=votre-cle-secrete-ici-changez-pour-la-production

# Configuration pour la production (Render)
# DATABASE_URL sera automatiquement fourni par Render (PostgreSQL)
# SECRET_KEY sera généré automatiquement par Render
# PORT sera fourni par Render (généralement 10000)
# FLASK_ENV=production sera défini par Render